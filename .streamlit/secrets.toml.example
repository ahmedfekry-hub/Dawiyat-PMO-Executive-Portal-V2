[email]
smtp_host = "smtp.office365.com"
smtp_port = 587
smtp_user = "your-email@company.com"
smtp_password = "your-password-or-app-password"
sender = "your-email@company.com"

# Google Drive document status scanning / manual upload workflow
# 1) Create a Google Cloud service account.
# 2) Enable Google Drive API.
# 3) Share the Link Codes root folder with service account client_email as Editor.
# 4) Never commit the real JSON key to GitHub. Paste the values only in Streamlit Secrets.
[google_drive]
root_folder_id = "PASTE_LINK_CODES_FOLDER_ID"

# The app supports either [gcp_service_account] or [google_service_account].
[gcp_service_account]
type = "service_account"
project_id = "your-project-id"
private_key_id = "..."
private_key = """-----BEGIN PRIVATE KEY-----
...
-----END PRIVATE KEY-----
"""
client_email = "your-service-account@your-project.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
universe_domain = "googleapis.com"


